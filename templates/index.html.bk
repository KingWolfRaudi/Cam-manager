<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cámara de la Chromebook</title>
    <style>
        body {
            display: flex;
            flex-direction: column;
            align-items: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #222;
            color: white;
            margin: 0;
            padding: 10px 15px; 
            box-sizing: border-box;
        }

        h1 {
            text-align: center;
            font-size: 1.6rem;
            margin-bottom: 15px;
        }

        /* --- CONTENEDOR DEL VISOR --- */
        .visor-container {
            width: 100%;
            max-width: 640px;
            aspect-ratio: 4 / 3;
            margin-bottom: 20px;
            position: relative;
        }

        /* La imagen de la cámara ahora está oculta por defecto */
        #visorCamara {
            border: 4px solid #555;
            border-radius: 10px;
            box-shadow: 0px 4px 10px rgba(0,0,0,0.5);
            width: 100%; 
            height: 100%;
            object-fit: contain; 
            background-color: #000; 
            display: none; 
        }

        /* Pantalla de reposo cuando la cámara está apagada */
        #placeholderCamara {
            border: 4px dashed #555;
            border-radius: 10px;
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: #777;
            font-size: 1.2rem;
            box-sizing: border-box;
        }

        .controles {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            justify-content: center;
            width: 100%;
            max-width: 640px;
            margin-bottom: 20px;
        }

        button, select {
            flex: 1 1 auto;
            min-width: 150px;
            padding: 12px 20px;
            font-size: 16px;
            cursor: pointer;
            border: none;
            border-radius: 5px;
            font-weight: bold;
            transition: background-color 0.3s, transform 0.1s;
            display: flex; 
            align-items: center;
            justify-content: center;
            gap: 8px;
            white-space: nowrap; 
        }

        button:active { transform: scale(0.95); }
        select { background-color: #555; color: white; border: 1px solid #777; }
        
        #btnEncendido { background-color: #4CAF50; color: white; width: 100%; max-width: 640px; margin-bottom: 20px;}
        #btnEncendido.activa { background-color: #f44336; }
        
        #btnFoto { background-color: #555; color: white; } /* Inicia en gris (desactivado) */
        #btnVideo { background-color: #555; color: white; }
        
        /* Clases dinámicas cuando la cámara se enciende */
        #btnFoto.lista { background-color: #4CAF50; }
        #btnFoto.lista:hover { background-color: #45a049; }
        #btnVideo.lista { background-color: #2196F3; }
        #btnVideo.lista:hover { background-color: #0b7dda; }
        #btnVideo.grabando { background-color: #f44336 !important; }

        @media (max-width: 768px) {
            .controles { display: grid; grid-template-columns: 1fr; gap: 10px; }
            button, select { width: 100%; height: 50px; }
        }
    </style>
</head>
<body>

    <h1>Servidor de Vigilancia</h1>
    
    <button id="btnEncendido" onclick="toggleCamara()">🔌 Encender Cámara</button>

    <div class="visor-container">
        <div id="placeholderCamara">
            <span>💤</span>
            <p>La cámara está apagada</p>
        </div>
        <img id="visorCamara" alt="Transmisión de la cámara">
    </div>

    <div class="controles">
        <select id="selectorResolucion" onchange="cambiarResolucion()">
            <option value="320x240">320 x 240 (Baja)</option>
            <option value="640x480" selected>640 x 480 (Estándar)</option>
            <option value="1280x720">1280 x 720 (HD)</option>
        </select>

        <button id="btnFoto" onclick="tomarFoto()">📸 Tomar Foto</button>
        <button id="btnVideo" onclick="grabarVideo()">🎥 Iniciar Grabación</button>
    </div>

    <script>
        let camaraEncendida = false;

        function toggleCamara() {
            let btnEncendido = document.getElementById('btnEncendido');
            let btnFoto = document.getElementById('btnFoto');
            let btnVideo = document.getElementById('btnVideo');
            let visor = document.getElementById('visorCamara');
            let placeholder = document.getElementById('placeholderCamara');

            fetch('/toggle_camara', { method: 'POST' })
                .then(res => res.text())
                .then(estado => {
                    if (estado === "encendida") {
                        camaraEncendida = true;
                        btnEncendido.innerText = "🔌 Apagar Cámara";
                        btnEncendido.classList.add("activa");
                        
                        // Activamos visualmente los botones de captura
                        btnFoto.classList.add("lista");
                        btnVideo.classList.add("lista");

                        // Ocultamos el reposo y mostramos la imagen
                        placeholder.style.display = "none";
                        visor.style.display = "block";
                        
                        // Añadimos un timestamp a la URL para forzar al navegador a conectar
                        visor.src = "{{ url_for('video_feed') }}?" + new Date().getTime();
                    } else {
                        camaraEncendida = false;
                        btnEncendido.innerText = "🔌 Encender Cámara";
                        btnEncendido.classList.remove("activa");
                        
                        // Desactivamos los botones
                        btnFoto.classList.remove("lista");
                        btnVideo.classList.remove("lista");
                        btnVideo.classList.remove("grabando");
                        btnVideo.innerText = "🎥 Iniciar Grabación";

                        // Mostramos el reposo y cortamos la conexión de la imagen
                        visor.style.display = "none";
                        visor.src = ""; 
                        placeholder.style.display = "flex";
                    }
                });
        }

        function tomarFoto() {
            if (!camaraEncendida) {
                alert("¡Debes encender la cámara primero!");
                return;
            }
            fetch('/tomar_foto', { method: 'POST' })
                .then(respuesta => {
                    if(respuesta.ok) alert('¡Foto guardada en la carpeta "capturas"!');
                });
        }

        function grabarVideo() {
            if (!camaraEncendida) {
                alert("¡Debes encender la cámara primero!");
                return;
            }
            
            let boton = document.getElementById('btnVideo');
            fetch('/toggle_video', { method: 'POST' })
                .then(respuesta => respuesta.text())
                .then(estado => {
                    if (estado === "grabando") {
                        boton.innerText = "⏹️ Detener Grabación";
                        boton.classList.add("grabando");
                    } else {
                        boton.innerText = "🎥 Iniciar Grabación";
                        boton.classList.remove("grabando");
                        alert('¡Video guardado en la carpeta "capturas"!');
                    }
                });
        }

        function cambiarResolucion() {
            let selector = document.getElementById('selectorResolucion');
            let dimensiones = selector.value.split('x');
            fetch('/set_resolucion', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ancho: dimensiones[0], alto: dimensiones[1] })
            });
        }
    </script>
</body>
</html>